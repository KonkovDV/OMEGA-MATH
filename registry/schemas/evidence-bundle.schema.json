{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omega.microphoenix.dev/schema/evidence-bundle.json",
  "title": "OMEGA Evidence Bundle",
  "description": "Schema for workspace evidence bundle artifacts generated by omega_runner or verify_evidence.",
  "oneOf": [
    {
      "$ref": "#/$defs/runtimeBundle"
    },
    {
      "$ref": "#/$defs/checksumBundle"
    }
  ],
  "$defs": {
    "artifactPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\.\\.)(.+)$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "runtimeArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "type",
        "checksum",
        "size_bytes"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/artifactPath"
        },
        "type": {
          "type": "string",
          "enum": [
            "log",
            "dataset",
            "proof-draft",
            "prover-result",
            "counterexample",
            "plot"
          ]
        },
        "checksum": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "runtimeBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "problem_id",
        "generated_at",
        "summary",
        "documents",
        "runs"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "problem_id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "generated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "bundle_path": {
          "$ref": "#/$defs/artifactPath"
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total_runs",
            "total_artifacts",
            "total_bytes",
            "by_type"
          ],
          "properties": {
            "total_runs": {
              "type": "integer",
              "minimum": 0
            },
            "total_artifacts": {
              "type": "integer",
              "minimum": 0
            },
            "total_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "by_type": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "role",
              "exists"
            ],
            "properties": {
              "path": {
                "$ref": "#/$defs/artifactPath"
              },
              "role": {
                "type": "string",
                "minLength": 1
              },
              "exists": {
                "type": "boolean"
              },
              "checksum": {
                "$ref": "#/$defs/sha256"
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "runs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "run_id",
              "route",
              "agent",
              "status",
              "verdict",
              "started",
              "finished",
              "artifacts"
            ],
            "properties": {
              "run_id": {
                "type": "string",
                "pattern": "^[a-z0-9-]+-[0-9]{8}-[0-9]{3}$"
              },
              "route": {
                "type": "string"
              },
              "agent": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "verdict": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "started": {
                "type": "string",
                "format": "date-time"
              },
              "finished": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              },
              "artifacts": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/runtimeArtifact"
                }
              }
            }
          }
        }
      }
    },
    "checksumBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "problem_id",
        "timestamp",
        "artifact_count",
        "total_size_bytes",
        "artifacts"
      ],
      "properties": {
        "problem_id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "bundle_path": {
          "$ref": "#/$defs/artifactPath"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "checksum_sha256",
              "size_bytes"
            ],
            "properties": {
              "path": {
                "$ref": "#/$defs/artifactPath"
              },
              "checksum_sha256": {
                "$ref": "#/$defs/sha256"
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "last_modified": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      }
    }
  }
}
